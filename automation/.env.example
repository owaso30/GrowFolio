# WordPress
WP_URL=https://growfolio-note.com
WP_USER=your_wp_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Claude（記事生成）— https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Flux 画像（fal.ai）— https://fal.ai/dashboard/keys
FAL_KEY=...

# モデル名（claude-sonnet-4-6 / fal-ai/flux-2-pro 等）は config/models.yaml で設定

# 任意: SERP競合分析
# SERPAPI_KEY=

# BitradeX アフィリエイト（自動記事の招待CTA）
BITRADEX_AFFILIATE_URL=https://...

# Amazonアソシエイト
AMAZON_AFFILIATE_TAG=your-amazon-tag-22

# --- 自動計測（Search Console + GA4）---
# GA4 管理画面 → 管理 → プロパティ設定 の「プロパティ ID」（数字のみ）
GA4_PROPERTY_ID=123456789
# Search Console のプロパティ URL（URLプレフィックスなら末尾スラッシュ付き推奨）
# ドメインプロパティの場合は sc-domain:growfolio-note.com
GSC_SITE_URL=https://growfolio-note.com/
# サービスアカウント鍵のどれか一方:
# 1) 鍵JSONファイルのパス
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
# 2) 鍵JSONの中身をそのまま（GitHub Actions ではこちらを Secret に）
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
